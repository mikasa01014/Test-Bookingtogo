# Copy this file to ".env" and fill in your own TMDB API key.
# Get a free key at: https://www.themoviedb.org/settings/api
#
# IMPORTANT: the EXPO_PUBLIC_ prefix is required — Expo only inlines
# environment variables that start with this prefix into the JS bundle.
EXPO_PUBLIC_TMDB_API_KEY=your_tmdb_api_key_here